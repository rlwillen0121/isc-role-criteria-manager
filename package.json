{
  "name": "sailpoint-ui-development-kit",
  "version": "1.3.1",
  "description": "SailPoint UI development kit",
  "homepage": "https://sailpoint.com",
  "author": {
    "name": "Philip Ellis",
    "email": "developer-relations@sailpoint.com"
  },
  "keywords": [
    "angular",
    "angular 17",
    "electron",
    "electron 30",
    "nodejs",
    "typescript",
    "jest",
    "playwright",
    "eslint",
    "sass",
    "windows",
    "mac",
    "linux"
  ],
  "main": "electron-dist/main.js",
  "private": true,
  "workspaces": [
    "app"
  ],
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run ng:serve\" \"npm run electron:dev\" --names \"angular,electron\" --prefix-colors \"#5C44E4,#FF3E00\"",
    "dev": "npm run start",
    "ng:serve": "ng serve",
    "build:all": "npm run build:sdk && npm run build:prod && npm run electron:build",
    "build": "npm run build:components && npm run electron:tsc && ng build --base-href ./",
    "build:components": "ng build sailpoint-components",
    "build:dev": "npm run build -- -c dev",
    "build:prod": "npm run build:components && npm run build -- -c production",
    "build:sdk": "node scripts/build-sailpoint-sdk.js",
    "build:publish": "npm run build:prod && npm run electron:build",
    "electron": "electron",
    "electron:tsc": "tsc -p tsconfig.serve.json",
    "electron:dev": "wait-on tcp:4200 && nodemon --watch ./app --exec \"npm run electron:tsc && electron . --serve\"",
    "electron:local": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder build",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "e2e": "npm run build:prod && playwright test -c e2e/playwright.config.ts e2e/",
    "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
    "version": "conventional-changelog -i CHANGELOG.md -s -r 0 && git add CHANGELOG.md",
    "lint": "ng lint",
    "lint:components": "ng lint sailpoint-components",
    "lint:all": "ng lint && ng lint sailpoint-components",
    "generate:component": "node scripts/generate-component.js"
  },
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/language-service": "21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@babel/runtime": "7.28.4",
    "@codemirror/autocomplete": "^6.0.1",
    "@codemirror/commands": "^6.0.1",
    "@codemirror/language": "^6.0.1",
    "@codemirror/legacy-modes": "6.5.1",
    "@codemirror/search": "^6.0.1",
    "@codemirror/state": "^6.0.1",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "^6.0.1",
    "@lezer/highlight": "^1.2.0",
    "@types/codemirror": "5.60.16",
    "axios": "^1.13.6",
    "codemirror": "^6.0.2",
    "cronstrue": "^3.3.0",
    "d3": "^7.9.0",
    "diff": "^8.0.3",
    "electron-context-menu": "^4.1.0",
    "electron-is-dev": "^3.0.1",
    "form-data": "^4.0.0",
    "js-yaml": "^4.1.1",
    "jsonpointer": "^5.0.1",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "lodash-es": "^4.17.23",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "sailpoint-api-client": "1.8.1",
    "sequential-workflow-designer": "^0.37.0",
    "sequential-workflow-designer-angular": "^0.37.0",
    "sequential-workflow-editor": "^0.14.8",
    "sequential-workflow-editor-model": "^0.14.8",
    "sequential-workflow-model": "^0.2.0",
    "thememirror": "^2.0.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-builders/jest": "^21.0.3",
    "@angular-eslint/builder": "^19.3.0",
    "@angular-eslint/eslint-plugin": "^19.3.0",
    "@angular-eslint/eslint-plugin-template": "^19.3.0",
    "@angular-eslint/schematics": "^19.3.0",
    "@angular-eslint/template-parser": "^19.3.0",
    "@angular/build": "^21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@babel/core": "7.28.0",
